#include <iostream>
#include <vector>
using namespace std;
int main()
{
    vector<double> productos = {150, 200, 500, 300};
    double descuento = 0.9;
    cout << "Verduleria" << endl << endl;
    cout << "Lista de productos sin descuentos:" << endl;
    cout << "Kg de papa: " << productos[0] << endl;
    cout << "Kg de morron: " << productos[1] << endl;
    cout << "Kg de cebolla: " << productos[2] << endl;
    cout << "Kg de zapallo: " << productos[3] << endl << endl;
    for(int i = 0; i < 4; i++)
    {
        productos[i] = productos[i] * descuento;
    }
    cout << "Precios finales:" << endl;
    cout << "Kilo de la papa: " << productos[0] << endl;
    cout << "Kilo del morron: " << productos[1] << endl;
    cout << "Kilo de la cebolla: " << productos[2] << endl;
    cout << "Kilo del zapallo: " << productos[3] << endl;
    return 0;
}
