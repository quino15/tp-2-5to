#include <iostream>
#include <vector>
using namespace std;
int main()
{
    vector<int> numeros = {1, 2, 3, 4, 5};
    vector<int> secuencia = {6, 7, 8, 9};
    int final[5];
    for(int i = 0; i < 5; i++)
    {
        if(i % 2 == 0)
        {
            final[i] = numeros[i];
        }
        if(i % 2 != 0)
        {
            final[i] = secuencia[i];
        }
    }
    for(int j = 0; j < 5; j++)
    {
        cout << final[j];
    }
    return 0;
}
