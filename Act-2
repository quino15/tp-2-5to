#include <iostream>
#include <vector>
using namespace std;
int main()
{
    int auxiliar = 1;
    int tamaño_de_vector = 0;
    vector<int> numeros = {tamaño_de_vector};
    cout << "Este programa muestra una secuencia sin repetir numeros." << endl;
    do
    {
        cout << "Ingrese el numero: ";
        cin >> auxiliar;
        numeros[tamaño_de_vector] = auxiliar;
        tamaño_de_vector = tamaño_de_vector + 1;
    }
    while(auxiliar != 0);
    if(auxiliar == 0)
    {
        for(int i = 0; i < tamaño_de_vector - 1; i++)
        {
            cout << numeros[i];
        }
    }
    return 0;
}
