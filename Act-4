#include <iostream>
#include <vector>
using namespace std;
int main()
{
    vector<int> numeros = {1, 2, 3, 4, 5};
    vector<int> secuencia = {6, 2, 8, 4, 9};
    vector<int> final = {0, 0, 0, 0, 0};
    for(int i = 0; i < 5; i++)
    {
        if(numeros[i] == secuencia[i])
        {
            final[i] = numeros[i];
        }
    }
    cout << "La interseccion es: ";
    for(int j = 0; j < 5; j++)
    {
        if(final[j] == 0)
        {
            j++;
            if(final[j] != 0)
            {
                cout << final[j] << ", ";
            }
        }
    }
    return 0;
}
